# ============================================================
# LANGCHAIN SECURITY RAG — Configuration
# ============================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Edit .env with your settings
#   3. Never commit .env to git (it has secrets)
# ============================================================

# ── LLM PROVIDER ────────────────────────────────────────────
# Which AI to use. Options: ollama (FREE), anthropic, openai
LLM_PROVIDER=ollama

# ── OLLAMA SETTINGS (FREE - runs on your computer) ──────────
# No API key needed! Just install Ollama and run: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2          # Text generation model
OLLAMA_EMBED_MODEL=nomic-embed-text # Embedding model

# ── PAID OPTIONS (leave blank if not using) ─────────────────
# How to get Claude API key (when ready):
#   1. Go to https://console.anthropic.com
#   2. Sign up / log in
#   3. Click "API Keys" → "Create Key"
#   4. Paste it below
ANTHROPIC_API_KEY=

# How to get OpenAI API key (when ready):
#   1. Go to https://platform.openai.com
#   2. Sign up / log in
#   3. Click your profile → "API Keys" → "Create new secret key"
#   4. Paste it below
OPENAI_API_KEY=

# ── RAG SETTINGS ────────────────────────────────────────────
# CHUNK_SIZE: How many characters per document chunk
#   Too small = missing context | Too large = noise
#   800 is a good balance for security docs
CHUNK_SIZE=800

# CHUNK_OVERLAP: Characters shared between adjacent chunks
#   Prevents cutting sentences mid-thought
CHUNK_OVERLAP=150

# TOP_K: How many chunks to retrieve per question
#   More = more context but slower and more tokens
TOP_K_RESULTS=4

# ── PATHS ───────────────────────────────────────────────────
VECTORSTORE_PATH=./vectorstore
PDFS_FOLDER=./pdfs
